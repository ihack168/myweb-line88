{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:year(20\\d{2})/:month(\\d{2})/:slug*.html",
      "destination": "https://blog.line88.tw/:year/:month/:slug*.html",
      "permanent": true
    },
    {
      "source": "/:year(20\\d{2})/:path*",
      "destination": "https://blog.line88.tw/:year/:path*",
      "permanent": true
    },
    {
      "source": "/search/label/:label*",
      "destination": "https://blog.line88.tw/search/label/:label*",
      "permanent": true
    },
    {
      "source": "/search",
      "destination": "https://blog.line88.tw/search",
      "permanent": true
    }
  ]
}